# ── Core ──────────────────────────────────────────────────────────────────
WEB_PORT=8080
WEB_PASS=changeme                      # password for regular users
WEB_ADMIN_PASS=changeme_admin          # password for admin (leave blank to disable admin)
WEB_BASE=https://files.example.com     # public URL shown in logs and share links

# ── Storage ───────────────────────────────────────────────────────────────
DOWNLOADS_DIR=downloads                # path to serve (relative or absolute)
MAX_UPLOAD_MB=2048                     # per-file upload cap in MB
MAX_FETCH_MB=4096                      # remote URL fetch cap in MB
QUOTA_MB=0                             # per-user disk quota in MB (0 = unlimited)

# ── Security ──────────────────────────────────────────────────────────────
LINK_SECRET=                           # HMAC secret for share tokens (auto-generated if blank — set explicitly in prod)
COOKIE_SECURE=false                    # set true when behind an HTTPS reverse proxy
MAX_SESSIONS_PER_USER=10               # max simultaneous sessions per account

# ── Telegram bot (optional — only needed if running bot.py) ───────────────
API_ID=
API_HASH=
BOT_TOKEN=
SF_USER=                               # SourceForge username for uploads
SF_PASS=                               # SourceForge password
SUPER_USERS=                           # comma-separated Telegram user IDs with delete rights

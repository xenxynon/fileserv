# ──────────────────────────────────────────────
# fileserv — environment configuration
# Copy to .env and fill in values before running
# ──────────────────────────────────────────────

# Server port (default: 8080)
PORT=8080

# Directory where the SQLite DB and metadata live
DATA_DIR=./data

# Root directory served to users
DOWNLOADS_DIR=./data/files

# Admin account password (auto-created on start)
# Leave empty to skip admin creation
ADMIN_PASS=changeme

# Secret used to sign download tokens and share links
# Generate with: openssl rand -hex 32
# REQUIRED for production — tokens break on restart if not set
LINK_SECRET=change_this_to_a_random_32_byte_hex_string

# Maximum upload size in megabytes (default: 2048)
MAX_UPLOAD_MB=2048

# Maximum remote fetch size in megabytes (default: 4096)
MAX_FETCH_MB=4096

# Per-user storage quota in MB (0 = unlimited)
QUOTA_MB=0

# Maximum concurrent sessions per user (default: 10)
MAX_SESSIONS_PER_USER=10

# Set to true when serving behind HTTPS (marks session cookie Secure)
COOKIE_SECURE=false

# Allow new users to self-register (default: true)
REGISTRATION_OPEN=true

# Optional: Webhook URL for event notifications
# WEBHOOK_URL=https://your-service.example.com/webhook
